{
  "version": 2,
  "builds": [
    {
      "src": "api/generate-plan.js",
      "use": "@vercel/node",
      "config": {
        "memory": 1024,
        "maxDuration": 30
      }
    },
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    {
      "src": "/api/generate-plan",
      "dest": "api/generate-plan.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/autopilot/content/tuesday-model",
      "schedule": "0 19 * * 2"
    },
    {
      "path": "/api/autopilot/content/thursday-course-stat",
      "schedule": "0 18 * * 4"
    }
  ]
}