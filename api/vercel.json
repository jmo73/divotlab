{
  "version": 2,
  "builds": [
    {
      "src": "api/generate-plan.js",
      "use": "@vercel/node",
      "config": {
        "memory": 1024,
        "maxDuration": 30
      }
    },
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    {
      "src": "/api/generate-plan",
      "dest": "api/generate-plan.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "crons": [
    { "path": "/api/autopilot/content/monday-field",        "schedule": "0 13 * * 1" },
    { "path": "/api/autopilot/content/tuesday-model",       "schedule": "0 13 * * 2" },
    { "path": "/api/autopilot/content/wednesday-top10",     "schedule": "0 13 * * 3" },
    { "path": "/api/autopilot/content/thursday-course-stat","schedule": "0 13 * * 4" },
    { "path": "/api/autopilot/content/friday-darkhorse",    "schedule": "0 13 * * 5" },
    { "path": "/api/autopilot/content/saturday-update",     "schedule": "0 13 * * 6" },
    { "path": "/api/autopilot/content/sunday-contenders",   "schedule": "0 13 * * 0" }
  ]
}