{
  "version": 2,
  "builds": [
    {
      "src": "api/generate-plan.js",
      "use": "@vercel/node",
      "config": {
        "memory": 1024,
        "maxDuration": 30
      }
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/generate-plan",
      "dest": "api/generate-plan.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}